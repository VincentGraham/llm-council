NGC_API_KEY=your_ngc_api_key_here
# Optional: override result storage location (default: /data/results)
DATA_DIR=/data/results
# Optional: override model config location (default: ./models.yaml)
MODELS_YAML=models.yaml
# Optional: endpoint host/scheme used to reach model containers (default: localhost/http)
MODEL_ENDPOINT_HOST=localhost
MODEL_ENDPOINT_SCHEME=http
# Optional per-model override example:
# MODEL_ENDPOINT_QWEN2_5_72B_INSTRUCT=http://qwen2-5-72b-instruct:8000/v1
